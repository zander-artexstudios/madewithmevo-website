# Supabase
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Simple admin gate for /admin
ADMIN_PASSWORD=change-this-password

# MEVO episode credit baseline (internal cost unit)
MEVO_EPISODE_BASE_COST=100

# MEVO provider mode (mock|openai|custom)
MEVO_PROVIDER_MODE=mock

# Retry ceiling for queue runner
MEVO_MAX_RETRIES=2
MEVO_RETRY_BACKOFF_MS=60000

# Scheduler auth key for run-due endpoint
MEVO_SCHEDULER_KEY=change-me

# Optional local-dev auth bypass user id
MEVO_DEV_USER_ID=

# Hard cap for motion shots per generated episode
MEVO_MAX_MOTION_SHOTS=2

# Base URL used for episode share links
MEVO_SHARE_BASE_URL=https://madewithmevo.com

# Secret used to sign view-only world invite links
MEVO_INVITE_SECRET=change-me-in-production

# Optional alpha recipient fallback for publish email stub
MEVO_NOTIFICATION_STUB_EMAIL_TO=
